PORT=8183
CH__SERVER__LOG_LEVEL=INFO
DATABASE_URL=postgres://budgy:CHANGE_ME@localhost:5432/custhome_budgy
BUDGY_ENCRYPTION_KEY=<base64 standard de 32 octets -- ex. openssl rand -base64 32>
JWT_SECRET=<identique au JWT_SECRET de CH-Api-Authenticator -- minimum 32 octets>
JWT_ISSUER=ch-api-authenticator
JWT_AUDIENCE=ch-api-budgy
RELAY_ENABLED=false
RELAY_URL=mqtt://127.0.0.1:1883
RELAY_CLIENT_ID=ch-api-budgy
RELAY_TOPIC_PREFIX=budgy
RELAY_EVENT_ISSUER=ch-api-budgy
RELAY_SERVICE_TOKEN=<jeton de service Relay -- requis seulement si RELAY_ENABLED=true>
RELAY_JWT_PRIVATE_KEY=<clé privée RS256 au format PEM -- requise seulement si RELAY_ENABLED=true>

